FREUD_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1090
source "$FREUD_CONFIG_DIR/default.env"

NEOPSYKE_LLM_CONFIG_FILE="${NEOPSYKE_LLM_CONFIG_FILE:-$FREUD_CONFIG_DIR/llm-low-llm.yaml}"
FREUD_REASONING_EVAL_MODEL_CMD="${FREUD_REASONING_EVAL_MODEL_CMD:-freud/scripts/run-bbh-smoke.sh --lane low-llm}"
FREUD_SESSION_REPLAY_TEST_CMD="${FREUD_SESSION_REPLAY_TEST_CMD:-freud/scripts/test-session-replay.sh --timeout 60}"
FREUD_LIVE_EVAL_TIMEOUT="${FREUD_LIVE_EVAL_TIMEOUT:-120}"
