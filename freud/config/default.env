# Freud adapter config for this repository (Psyke).
# Keep this file project-specific; keep freud/scripts generic.

FREUD_PROJECT_NAME="${FREUD_PROJECT_NAME:-psyke}"
FREUD_RUN_ROOT="${FREUD_RUN_ROOT:-.psyke/runs/freud}"
FREUD_GRADLE_USER_HOME="${FREUD_GRADLE_USER_HOME:-.freud/gradle-home}"

# Pre-flight compile (fast fail on syntax/type errors before running any tests).
FREUD_PREFLIGHT_COMPILE_CMD="${FREUD_PREFLIGHT_COMPILE_CMD:-./gradlew compileKotlin compileTestKotlin}"

# Deterministic checks (default loop mode).
FREUD_TARGETED_TEST_CMD="${FREUD_TARGETED_TEST_CMD:-./gradlew :test --tests 'psyke.agent.*'}"
FREUD_FULL_TEST_CMD="${FREUD_FULL_TEST_CMD:-./gradlew test}"
FREUD_SCENARIO_PACK_CMD="${FREUD_SCENARIO_PACK_CMD:-freud/scripts/run-scenarios.sh --file freud/scenarios/v1/psyke-agent-scenarios.json}"
FREUD_REASONING_EVAL_LOGIC_CMD="${FREUD_REASONING_EVAL_LOGIC_CMD:-./run-psyke.sh --eval-reasoning-only --eval-reasoning-mode logic}"

# Optional live checks. Keep blank by default to avoid accidental paid/live runs.
FREUD_REASONING_EVAL_MODEL_CMD="${FREUD_REASONING_EVAL_MODEL_CMD:-}"
FREUD_MEMORY_SMOKE_CMD="${FREUD_MEMORY_SMOKE_CMD:-}"

# AI-powered failure triage: runs after any step failure to suggest a root cause + fix.
# Uses the same provider keys as the summarizer. Set to '' to disable.
FREUD_AI_TRIAGE_CMD="${FREUD_AI_TRIAGE_CMD:-freud/scripts/ai-triage-failure.sh --if-configured}"
FREUD_TRIAGE_PROVIDER="${FREUD_TRIAGE_PROVIDER:-auto}"
FREUD_TRIAGE_MAX_OUTPUT_TOKENS="${FREUD_TRIAGE_MAX_OUTPUT_TOKENS:-500}"

# Tier-2 optional cheap-model summarization (safe default: skip when not configured).
FREUD_SUMMARIZER_CMD="${FREUD_SUMMARIZER_CMD:-freud/scripts/cheap-summarizer-adapter.sh --if-configured}"
FREUD_SUMMARIZER_PROVIDER="${FREUD_SUMMARIZER_PROVIDER:-auto}"
FREUD_SUMMARIZER_MODEL="${FREUD_SUMMARIZER_MODEL:-}"
FREUD_SUMMARIZER_ENABLE_FALLBACK="${FREUD_SUMMARIZER_ENABLE_FALLBACK:-true}"
FREUD_SUMMARIZER_FALLBACK_ORDER="${FREUD_SUMMARIZER_FALLBACK_ORDER:-openai,mistral,groq}"
FREUD_SUMMARIZER_HEALTHCHECK_TIMEOUT_SEC="${FREUD_SUMMARIZER_HEALTHCHECK_TIMEOUT_SEC:-6}"
FREUD_SUMMARIZER_TOKEN_LIMIT="${FREUD_SUMMARIZER_TOKEN_LIMIT:-50000000}"

# Loop behavior.
FREUD_CONTINUE_ON_FAIL="${FREUD_CONTINUE_ON_FAIL:-false}"
