# Freud adapter config for this repository (NeoPsyke).
# Keep this file project-specific; keep freud/scripts generic.

FREUD_PROJECT_NAME="${FREUD_PROJECT_NAME:-neopsyke}"
FREUD_RUN_ROOT="${FREUD_RUN_ROOT:-.neopsyke/runs/freud}"
FREUD_GRADLE_USER_HOME="${FREUD_GRADLE_USER_HOME:-.freud/gradle-home}"

# Pre-flight compile (fast fail on syntax/type errors before running any tests).
FREUD_PREFLIGHT_COMPILE_CMD="${FREUD_PREFLIGHT_COMPILE_CMD:-./gradlew compileKotlin compileTestKotlin}"

# Deterministic checks (default loop mode).
# `./gradlew test` is only the Kotlin/JVM test subset. The deterministic
# completion/signoff gate is `freud/scripts/feature-loop.sh ci-pr`, which also
# runs the deterministic scenario pack and reasoning gate.
# `FREUD_TARGETED_TEST_CMD` is an iteration-speed subset and does not replace
# `FREUD_FULL_TEST_CMD`.
FREUD_TARGETED_TEST_CMD="${FREUD_TARGETED_TEST_CMD:-./gradlew :test --tests 'ai.neopsyke.agent.*'}"
FREUD_FULL_TEST_CMD="${FREUD_FULL_TEST_CMD:-./gradlew test}"
FREUD_SCENARIO_PACK_CMD="${FREUD_SCENARIO_PACK_CMD:-freud/scripts/run-scenarios.sh --file freud/scenarios/v1/neopsyke-agent-scenarios.json}"
FREUD_REASONING_EVAL_LOGIC_CMD="${FREUD_REASONING_EVAL_LOGIC_CMD:-freud/scripts/run-reasoning-pr-gate.sh}"

# Keep scratchpad debug dumps enabled in Freud flows.
export EGO_SCRATCHPAD_DEBUG_CAPTURE_ENABLED="${EGO_SCRATCHPAD_DEBUG_CAPTURE_ENABLED:-true}"

# Disable Id module in all Freud flows to prevent autonomous impulses during evals.
export NEOPSYKE_ID_ENABLED="${NEOPSYKE_ID_ENABLED:-false}"

# Disable goals runtime in Freud flows by default.
export NEOPSYKE_GOALS_ENABLED="${NEOPSYKE_GOALS_ENABLED:-false}"

# Optional live checks. Keep blank by default to avoid accidental paid/live runs.
# Use a live config such as freud/config/live-weak-structure.env or
# freud/config/live-prod-acceptance.env when you intentionally want live steps.
FREUD_REASONING_EVAL_MODEL_CMD="${FREUD_REASONING_EVAL_MODEL_CMD:-}"
FREUD_MEMORY_SMOKE_CMD="${FREUD_MEMORY_SMOKE_CMD:-}"
FREUD_SESSION_REPLAY_TEST_CMD="${FREUD_SESSION_REPLAY_TEST_CMD:-}"

# Freud live eval defaults.
FREUD_LIVE_EVAL_TIMEOUT="${FREUD_LIVE_EVAL_TIMEOUT:-120}"
FREUD_LIVE_EVAL_PRESERVE_MEMORY="${FREUD_LIVE_EVAL_PRESERVE_MEMORY:-false}"

# Run retention: delete run directories older than this many days.
# Covers file-based state (logbook, metrics, action-control) and pgvector namespaces.
FREUD_RUN_RETENTION_DAYS="${FREUD_RUN_RETENTION_DAYS:-3}"
FREUD_BBH_MIN_PASS_RATE_PERCENT="${FREUD_BBH_MIN_PASS_RATE_PERCENT:-100}"
FREUD_BBH_MAX_TIMEOUTS="${FREUD_BBH_MAX_TIMEOUTS:-0}"
FREUD_BBH_PRESERVE_MEMORY="${FREUD_BBH_PRESERVE_MEMORY:-false}"
FREUD_BBH_MEMORY_ENABLED="${FREUD_BBH_MEMORY_ENABLED:-false}"
FREUD_BBH_LOGBOOK_ENABLED="${FREUD_BBH_LOGBOOK_ENABLED:-false}"

# Loop behavior.
FREUD_CONTINUE_ON_FAIL="${FREUD_CONTINUE_ON_FAIL:-false}"
